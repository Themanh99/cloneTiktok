{
  "info": {
    "name": "TikTokWeb API",
    "description": "API collection for TikTokWeb backend.\n\n**Setup:**\n1. Create an environment with `baseUrl` = `http://localhost:3000`\n2. Register/Login to get tokens\n3. Set `accessToken` variable from the login response\n\n**i18n:**\nError responses include a `messageCode` field for frontend i18n lookup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints: register, login, refresh, logout, Google OAuth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Create a new user account",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\",\n  \"username\": \"johndoe\",\n  \"displayName\": \"John Doe\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login with email and password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Get a new access token using a refresh token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<paste_refresh_token_here>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Invalidate the refresh token",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"<paste_refresh_token_here>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "google"
              ]
            },
            "description": "Login or register with a Google ID token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<google_id_token>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profile, follow/unfollow, search endpoints",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            },
            "description": "Get current authenticated user profile",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            },
            "description": "Update current user profile",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"New Display Name\",\n  \"bio\": \"My bio here\",\n  \"avatarUrl\": \"https://example.com/avatar.jpg\",\n  \"dob\": \"2000-01-15\",\n  \"gender\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "john",
                  "description": "Search keyword",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of results (1-100)",
                  "disabled": false
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Cursor for pagination",
                  "disabled": true
                }
              ]
            },
            "description": "Search users by username or display name"
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<id>",
                  "description": "id parameter"
                }
              ]
            },
            "description": "Get a user public profile by ID"
          }
        },
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id/follow",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                ":id",
                "follow"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<id>",
                  "description": "id parameter"
                }
              ]
            },
            "description": "Follow a user",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Unfollow User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id/follow",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                ":id",
                "follow"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<id>",
                  "description": "id parameter"
                }
              ]
            },
            "description": "Unfollow a user",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get Followers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id/followers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                ":id",
                "followers"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of results",
                  "disabled": false
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Cursor for pagination",
                  "disabled": true
                }
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<id>",
                  "description": "id parameter"
                }
              ]
            },
            "description": "Get list of followers for a user"
          }
        },
        {
          "name": "Get Following",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/:id/following",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                ":id",
                "following"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of results",
                  "disabled": false
                },
                {
                  "key": "cursor",
                  "value": "",
                  "description": "Cursor for pagination",
                  "disabled": true
                }
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<id>",
                  "description": "id parameter"
                }
              ]
            },
            "description": "Get list of users a user is following"
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ]
}